APP_NAME=fixflow-backend
APP_ENV=development
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GRPC_PORT=9090
LOG_LEVEL=debug

POSTGRES_URL=postgres://fixflow:fixflow@127.0.0.1:5433/fixflow?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fixflow
MINIO_USE_SSL=false

JWT_SECRET=change-me
JWT_EXPIRY_HOURS=24

JAEGER_ENDPOINT=http://localhost:16686
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
